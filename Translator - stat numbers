//Sort keys longest first
let sortedKeys = Object.keys(statMap).sort((a, b) => b.length - a.length)

let line = args[0]

//Chuck dem numbers
sortedKeys.forEach(key => {
    if (line.includes(key)) {

        let replacement = key + statMap[key]

        gwc.output.replace(
            key,
            '<span style="font-weight:bold">' + replacement + '</span>',
            true
        )
    }
})
