Trigger: Noigo maze

Regexp pattern: The trees here are (.*)|They are (.*)|This is a (.*)|It's a few (.*)

Execute Javascript:

// initialize storage if needed
if (!gwc.userdata.maze) {
  gwc.userdata.maze = {
    trees: "",
    flowers: "",
    bushes: ""
  };
}


// trees
if (args[1] == "old heavy oaks."){gwc.userdata.maze.trees = "A"}
if (args[1] == "leafy birches.") {gwc.userdata.maze.trees = "B"}
if (args[1] == "high pines.") {gwc.userdata.maze.trees = "C"}

// flowers
if (args[4] == "lonely lilies.") {gwc.userdata.maze.flowers = "A"}
if (args[2] == "white roses, with an adorable smell.") {gwc.userdata.maze.flowers = "B"}
if (args[2] == "anemones.") {gwc.userdata.maze.flowers = "C"}

// bushes
if (args[3] == "dark green bush.") {gwc.userdata.maze.bushes = "A"}
if (args[3] == "green bush.") {gwc.userdata.maze.bushes = "B"}
if (args[3] == "light green bush.") { gwc.userdata.maze.bushes = "C"}
